HRV

const DAILY_FOLDER = "02-Cowork/Health/Daily";
const ws = dv.current().week_start;
const we = dv.current().week_end;
const pages = dv.pages(`"${DAILY_FOLDER}"`)
  .where(p => p.date && p.date >= ws && p.date <= we)
  .sort(p => p.date, 'asc');
const labels = pages.map(p => p.date.toFormat("EEE")).values;
const data   = pages.map(p => p.hrv ?? null).values;
const chartData = {
  type: 'line',
  data: {
    labels,
    datasets: [{
      label: 'HRV (ms)',
      data,
      borderColor: '#689d6a',
      backgroundColor: 'rgba(104,157,106,0.12)',
      tension: 0.35,
      fill: true,
      spanGaps: true,
      pointRadius: 4,
      pointBackgroundColor: '#689d6a'
    }]
  },
  options: {
    plugins: { legend: { display: false } },
    scales: {
      y: { beginAtZero: false, grid: { color: 'rgba(168,153,132,0.15)' } },
      x: { grid: { color: 'rgba(168,153,132,0.15)' } }
    }
  }
};
if (window.renderChart) window.renderChart(chartData, this.container);
else dv.paragraph('⚠️ Enable phibr0/obsidian-charts');

